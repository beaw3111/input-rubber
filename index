        function populateFarmerDropdown(scaleId) {
            const farmerSelector = document.getElementById(`farmer-selector-${scaleId}`);
            const allDatesWithData = Object.keys(dailyData).filter(date => dailyData[date]).sort().reverse();
            let startIndex = allDatesWithData.indexOf(selectedDate);
            if (startIndex === -1) {
                startIndex = 0;
            }
            const relevantDates = allDatesWithData.slice(startIndex, startIndex + 4);

            let allReceivingEntries = [];
            relevantDates.forEach(date => {
                if (dailyData[date] && dailyData[date][scaleId]) {
                    allReceivingEntries.push(...dailyData[date][scaleId]);
                }
            });

            const unbilledEntries = allReceivingEntries.filter(item => !item.billed);
            unbilledEntries.sort((a, b) => a.timestamp - b.timestamp);

            const uniqueNamesInOrder = [];
            const seenNames = new Set();
            unbilledEntries.forEach(item => {
                if (!seenNames.has(item.name)) {
                    uniqueNamesInOrder.push(item.name);
                    seenNames.add(item.name);
                }
            });

            farmerSelector.innerHTML = '<option value="">-- เลือกลูกค้า --</option>';
            uniqueNamesInOrder.forEach(name => {
                farmerSelector.innerHTML += `<option value="${name}">${name}</option>`;
            });
            resetBillingForm(scaleId);
        }

        function resetBillingForm(scaleId) {
            document.getElementById(`farmer-total-bags-${scaleId}`).textContent = '0.00';
            weightEntries[scaleId] = [];
            updateWeightDisplay(scaleId);
            calculateBill(scaleId);
        }

        function updateFarmerTotalBags(scaleId) {
            const farmerSelector = document.getElementById(`farmer-selector-${scaleId}`);
            const selectedFarmer = farmerSelector.value;
            resetBillingForm(scaleId);
            if (!selectedFarmer) return;

            const allDatesWithData = Object.keys(dailyData).filter(date => dailyData[date]).sort().reverse();
            let startIndex = allDatesWithData.indexOf(selectedDate);
            if (startIndex === -1) {
                startIndex = 0;
            }
            const relevantDates = allDatesWithData.slice(startIndex, startIndex + 4);

            let totalBags = 0;
            relevantDates.forEach(date => {
                if (dailyData[date] && dailyData[date][scaleId]) {
                    const bagsForDate = dailyData[date][scaleId]
                        .filter(item => item.name === selectedFarmer && !item.billed)
                        .reduce((sum, item) => sum + item.bags, 0);
                    totalBags += bagsForDate;
                }
            });
            
            document.getElementById(`farmer-total-bags-${scaleId}`).textContent = totalBags.toLocaleString('th-TH');
        }

        function updateWeightDisplay(scaleId) {
            const display = document.getElementById(`weight-display-${scaleId}`);
            display.innerHTML = '';
            if (!weightEntries[scaleId] || weightEntries[scaleId].length === 0) {
                display.innerHTML = '<span class="text-gray-400">ยังไม่มีการบันทึกน้ำหนัก</span>';
            } else {
                weightEntries[scaleId].forEach((weight, index) => {
                    const weightTagHTML = `
                        <div class="bg-sky-100 text-sky-800 text-sm font-semibold px-3 py-1.5 rounded-full flex items-center gap-2 shadow-sm">
                            <span>${weight.toLocaleString('th-TH', {minimumFractionDigits: 2, maximumFractionDigits: 2})}</span>
                            <button type="button" data-scale-id="${scaleId}" data-index="${index}" class="delete-weight-btn text-sky-600 hover:text-sky-800">
                                <i class="fas fa-times-circle"></i>
                            </button>
                        </div>
                    `;
                    display.innerHTML += weightTagHTML;
                });
            }
        }

        function calculateBill(scaleId) {
            const totalWeight = weightEntries[scaleId].reduce((sum, val) => sum + val, 0);
            const price = parseFloat(document.getElementById('global-price-input').value) || 0;
            const netAmount = totalWeight * price;
            
            const totalWeightDisplay = document.getElementById(`total-weight-display-${scaleId}`);
            if (totalWeightDisplay) {
                totalWeightDisplay.textContent = `${totalWeight.toLocaleString('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 })} กก.`;
            }
            
            document.getElementById(`net-amount-${scaleId}`).textContent = `${netAmount.toLocaleString('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 })} บาท`;
        }

        function updateBillingSummary(scaleId) {
            const billsForScale = savedBills.filter(b => b.date === selectedDate && b.scaleId === scaleId);
            const totalWeight = billsForScale.reduce((sum, bill) => sum + bill.totalWeight, 0);
            const totalValue = billsForScale.reduce((sum, bill) => sum + bill.netAmount, 0);

