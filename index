            if (currentUserRole === 'admin') {
                receiptsMenu.style.display = 'flex';
                truckLogMenu.style.display = 'flex';
            } else if (currentUserRole === 'staff') {
                receiptsMenu.style.display = 'none';
                truckLogMenu.style.display = 'none';
            }
