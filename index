        function renderReport(scaleId) {
            const container = document.getElementById(`report-${scaleId}`);
            const scalesForDate = getScalesDataForDate(selectedDate);
            const data = scalesForDate[scaleId] || [];

            const searchQuery = (receivingSearchQueries[scaleId] || '').toLowerCase().trim();
            let filteredData = data;
