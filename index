        /* Print Styles */
        @media print {
            html, body {
                height: auto !important;
                overflow: visible !important;
            }
            body.printing-active > *:not(#print-container) {
                display: none !important;
            }
            body.printing-active #print-container {
                display: block !important;
            }
            @page {
                size: A4 portrait;
                margin: 0;
            }
            .print-page {
                page-break-after: always;
                padding: 20mm 15mm;
