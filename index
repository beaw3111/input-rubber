        function switchPage(pageId) {
            if (currentUserRole === 'staff' && (pageId === 'page-receipts' || pageId === 'page-truck-log')) {
                console.warn(`Access denied for role '${currentUserRole}' to page '${pageId}'.`);
                return;
            }
            activePage = pageId;
            pages.forEach(page => page.classList.add('hidden'));
            document.getElementById(pageId).classList.remove('hidden');

            document.querySelectorAll('.menu-item').forEach(item => {
                const isSelected = item.dataset.page === pageId;
                item.classList.toggle('bg-gray-700', isSelected);
                item.classList.toggle('text-white', isSelected);
                item.classList.toggle('text-gray-300', !isSelected);
                if (isSelected) {
                    pageTitle.textContent = item.querySelector('span').textContent;
                }
            });

            refreshCurrentPage();
        }

        function switchTab(targetId) {
            activeTabId = targetId;
            document.querySelectorAll('.tab-pane').forEach(p => p.classList.add('hidden'));
            const targetPane = document.getElementById(targetId);
            if (targetPane) targetPane.classList.remove('hidden');

            document.querySelectorAll('#tabs a').forEach(t => {
                const isSelected = t.dataset.target === targetId;
                t.classList.toggle('border-indigo-500', isSelected);
                t.classList.toggle('text-indigo-600', isSelected);
                t.classList.toggle('border-transparent', !isSelected);
                t.classList.toggle('text-gray-500', !isSelected);
                t.classList.toggle('hover:border-gray-300', !isSelected);
                t.classList.toggle('hover:text-gray-700', !isSelected);
