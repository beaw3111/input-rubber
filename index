            const receiptsDateSelector = document.getElementById('receipts-date-selector');
            const globalPriceInput = document.getElementById('global-price-input');
            const truckLogListContainer = document.getElementById('truck-log-list-container');
            const receiptsPage = document.getElementById('page-receipts');

            mainMenu.addEventListener('click', e => {
                e.preventDefault();
                const menuItem = e.target.closest('.menu-item');
                if (menuItem) {
                    switchPage(menuItem.dataset.page);
                    sidebar.classList.add('-translate-x-full');
                    sidebarOverlay.classList.add('hidden');
                    contentWrapper.classList.remove('md:ml-64');
                }
            });
            sidebarToggle.addEventListener('click', () => {
                sidebar.classList.toggle('-translate-x-full');
                sidebarOverlay.classList.toggle('hidden');
                if (!sidebar.classList.contains('-translate-x-full')) {
                    contentWrapper.classList.add('md:ml-64');
                } else {
                    contentWrapper.classList.remove('md:ml-64');
                }
            });
            sidebarOverlay.addEventListener('click', () => {
                sidebar.classList.add('-translate-x-full');
                sidebarOverlay.classList.add('hidden');
                contentWrapper.classList.remove('md:ml-64');
            });

            [dateSelector, billingDateSelector, truckLogDateSelector].forEach(selector => {
                if (selector) {
                    selector.addEventListener('change', (e) => {
                        selectedDate = e.target.value;
                        document.querySelectorAll('select[id$="-date-selector"]').forEach(sel => sel.value = e.target.value);
                        refreshCurrentPage();
                    });
                }
            });

            receiptsDateSelector.addEventListener('change', () => {
                receiptCurrentPage = 1;
                renderReceiptsPage();
            });

            globalPriceInput.addEventListener('input', () => {
                if(activeBillingTabId !== 'billing-total-summary') {
                    calculateBill(activeBillingTabId);
                }
            });
            
            tabsContainer.addEventListener('click', e => {
                e.preventDefault();
                const tabItem = e.target.closest('a');
                if (tabItem && tabItem.dataset.target) {
                    switchTab(tabItem.dataset.target);
                }
            });
            
            billingTabsContainer.addEventListener('click', e => {
                e.preventDefault();
                const tabItem = e.target.closest('.billing-tab-item');
                if (tabItem) switchBillingTab(tabItem.dataset.target);
            });
            
             billingTabContentContainer.addEventListener('input', e => {
                if (e.target.id.startsWith('truck-target-weight-')) {
                    const scaleId = e.target.id.replace('truck-target-weight-', '');
                    const targetValue = parseFloat(e.target.value) || 0;
                    truckWeightTargets[scaleId] = targetValue;
                    updateDailyBilledSummary();
                } else if (e.target.id.startsWith('search-billing-history-')) {
                    const scaleId = e.target.id.replace('search-billing-history-', '');
                    billingHistorySearchQueries[scaleId] = e.target.value;
                    billingHistoryCurrentPage[scaleId] = 1;
                    renderBillingHistory(scaleId);
                }
            });

            billingTabContentContainer.addEventListener('change', e => {
                if (e.target.id.startsWith('farmer-selector-')) {
                    const scaleId = e.target.id.replace('farmer-selector-', '');
                    updateFarmerTotalBags(scaleId);
                }
            });

            billingTabContentContainer.addEventListener('click', async (e) => {
                const btn = e.target.closest('button');
                if (!btn) return;

                if (btn.classList.contains('billing-history-pagination-btn')) {
                    const scaleId = btn.dataset.scaleId;
                    const page = Number(btn.dataset.page);
                    billingHistoryCurrentPage[scaleId] = page;
                    renderBillingHistory(scaleId);
                    return;
                }
                if (btn.classList.contains('toggle-history-btn')) {
                    const targetId = btn.dataset.target;
                    const targetElement = document.getElementById(targetId);
                    const icon = btn.querySelector('i');
                    if (targetElement) {
                        targetElement.classList.toggle('hidden');
                        if (targetElement.classList.contains('hidden')) {
                            icon.classList.remove('fa-eye');
                            icon.classList.add('fa-eye-slash');
                        } else {
                            icon.classList.remove('fa-eye-slash');
                            icon.classList.add('fa-eye');
                        }
                    }
                    return;
                }
                if (btn.classList.contains('delete-weight-btn')) {
                    const scaleId = btn.dataset.scaleId;
                    const index = parseInt(btn.dataset.index, 10);
                    if (!isNaN(index) && weightEntries[scaleId]?.[index] !== undefined) {
                        weightEntries[scaleId].splice(index, 1);
                        updateWeightDisplay(scaleId);
                        calculateBill(scaleId);
                    }
                    return;
                }
                if (btn.classList.contains('add-new-farmer-btn')) {
                    const scaleId = btn.dataset.scaleId;
                    const nameInput = document.getElementById(`new-farmer-name-${scaleId}`);
                    const bagsInput = document.getElementById(`new-farmer-bags-${scaleId}`);
                    const newName = nameInput.value.trim();
                    const newBags = parseFloat(bagsInput.value);

                    if (!newName || isNaN(newBags) || newBags <= 0) {
                        alert('กรุณากรอกชื่อและจำนวนถุงให้ถูกต้อง');
                        return;
                    }

                    toggleButtonLoading(btn, true);
                    try {
                        await addDoc(collection(db, "receivingEntries"), {
                            name: newName, bags: newBags, billed: false,
                            date: selectedDate, scaleId: scaleId, timestamp: Date.now()
                        });
                        alert(`เพิ่มรายการ "${newName}" จำนวน ${newBags} ถุง เรียบร้อยแล้ว`);
                        nameInput.value = '';
                        bagsInput.value = '';
                    } catch (error) {
                        console.error("Error adding new farmer entry:", error);
                        alert("เกิดข้อผิดพลาดในการเพิ่มข้อมูล");
                    } finally {
                        toggleButtonLoading(btn, false);
                    }
                    return;
                }

                if (btn.classList.contains('add-weight-btn')) {
                    const scaleId = btn.dataset.scaleId;
                    const weightInput = document.getElementById(`weight-entry-${scaleId}`);
                    const weightValue = parseFloat(weightInput.value);
                    if (!isNaN(weightValue) && weightValue > 0) {
                        weightEntries[scaleId].push(weightValue);
                        updateWeightDisplay(scaleId);
                        calculateBill(scaleId);
                        weightInput.value = '';
                        weightInput.focus();
                    }
                } else if (btn.classList.contains('save-bill-btn')) {
                    const scaleId = btn.dataset.scaleId;
                    const farmerSelector = document.getElementById(`farmer-selector-${scaleId}`);
                    const farmerName = farmerSelector.value;
                    const totalWeight = weightEntries[scaleId].reduce((sum, val) => sum + val, 0);
                    const pricePerUnit = parseFloat(globalPriceInput.value) || 0;

                    if (!farmerName || totalWeight <= 0 || pricePerUnit <= 0) {
                        alert('กรุณากรอกข้อมูลให้ครบถ้วน: ชื่อลูกค้า, น้ำหนัก, และราคา');
                        return;
                    }
                    
                    const allDatesWithData = Object.keys(dailyData).filter(date => dailyData[date]).sort().reverse();
                    let startIndex = allDatesWithData.indexOf(selectedDate);
                    if (startIndex === -1) startIndex = 0;
                    const relevantDates = allDatesWithData.slice(startIndex, startIndex + 4);
                    const allSourceEntries = [];
                    relevantDates.forEach(date => {
                        if (dailyData[date]?.[scaleId]) {
                            const entries = dailyData[date][scaleId].filter(item => item.name === farmerName && !item.billed);
                            allSourceEntries.push(...entries);
                        }
                    });

                    if (allSourceEntries.length === 0) {
                        alert(`ไม่พบรายการรับวางยางที่ยังไม่ได้ออกบิลสำหรับคุณ ${farmerName}`);
                        return;
                    }
                    
                    toggleButtonLoading(btn, true);
                    try {
                        const batch = writeBatch(db);
                        const newBillRef = doc(collection(db, "bills"));
                        batch.set(newBillRef, {
                            date: selectedDate, farmerName, scaleId, totalWeight, pricePerUnit,
                            netAmount: totalWeight * pricePerUnit, timestamp: Date.now(),
                            printCount: 0, sourceEntryIds: allSourceEntries.map(e => e.id), loadedOnTruck: false
                        });
                        allSourceEntries.forEach(entry => {
                            const entryRef = doc(db, "receivingEntries", entry.id);
                            batch.update(entryRef, { billed: true });
                        });
                        await batch.commit();
                        alert(`บันทึกบิลสำหรับคุณ ${farmerName} เรียบร้อยแล้ว`);
                    } catch (error) {
                        console.error("Error saving bill: ", error);
                        alert("เกิดข้อผิดพลาดในการบันทึกบิล");
                    } finally {
                        toggleButtonLoading(btn, false);
                    }
                } else if (btn.classList.contains('save-to-truck-btn')) {
                    const scaleId = btn.dataset.scaleId;
                    document.getElementById('truck-log-scale-id').value = scaleId;
                    showModal('truck-log-modal');
                }
            });

            tabContentContainer.addEventListener('input', e => {
                if (e.target.id.startsWith('search-receiving-')) {
                    const scaleId = e.target.id.replace('search-receiving-', '');
                    receivingSearchQueries[scaleId] = e.target.value;
                    receivingCurrentPage[scaleId] = 1;
                    renderReport(scaleId);
                }
            });

            tabContentContainer.addEventListener('submit', async (e) => {
                e.preventDefault();
                const btn = e.target.querySelector('button[type="submit"]');
                if (e.target.tagName === 'FORM') {
                    const scaleId = e.target.id.replace('form-', '');
                    const name = document.getElementById(`name-${scaleId}`).value.trim();
                    const bags = parseFloat(document.getElementById(`bags-${scaleId}`).value);
                    if (name && !isNaN(bags) && bags >= 0) {
                        toggleButtonLoading(btn, true);
                        try {
                            await addDoc(collection(db, "receivingEntries"), {
                                name, bags, date: selectedDate, scaleId,
                                billed: false, timestamp: Date.now()
                            });
                            e.target.reset();
                            document.getElementById(`name-${scaleId}`).focus();
                        } catch (error) {
                            console.error("Error adding receiving entry:", error);
                            alert("เกิดข้อผิดพลาดในการบันทึกข้อมูล");
                        } finally {
                            toggleButtonLoading(btn, false);
                        }
                    }
                }
            });

            tabContentContainer.addEventListener('click', e => {
                const btn = e.target.closest('button');
                if (!btn) return;

                if (btn.classList.contains('receiving-pagination-btn')) {
                    const scaleId = btn.dataset.scaleId;
                    const page = Number(btn.dataset.page);
                    receivingCurrentPage[scaleId] = page;
                    renderReport(scaleId);
                    return;
                }
                const id = btn.dataset.id;
                if (btn.classList.contains('delete-btn')) {
                    itemToDeleteId = id;
                    billToDeleteId = null;
                    showModal('delete-confirm-modal');
                } else if (btn.classList.contains('edit-btn')) {
                    const item = getScalesDataForDate(selectedDate)[activeTabId].find(i => i.id === id);
                    if (item) {
                        document.getElementById('edit-item-id').value = item.id;
                        document.getElementById('edit-name').value = item.name;
                        document.getElementById('edit-bags').value = item.bags;
                        showModal('edit-modal');
                    }
                } else if (btn.classList.contains('print-btn')) {
                    printReceivingReport(btn.dataset.scaleId);
                }
            });

            if (receiptsPage) {
                receiptsPage.addEventListener('input', e => {
                    if (e.target.id === 'search-receipts') {
                        receiptsSearchQuery = e.target.value;
                        receiptCurrentPage = 1;
                        renderReceiptsPage();
                    }
                });

                receiptsPage.addEventListener('click', (e) => {
                    const btn = e.target.closest('button');
                    const header = e.target.closest('.sortable-header');

                    if (header) {
                        const sortBy = header.dataset.sortBy;
                        if (sortBy) {
                            if (receiptsSortColumn === sortBy) {
                                receiptsSortDirection = receiptsSortDirection === 'asc' ? 'desc' : 'asc';
                            } else {
                                receiptsSortColumn = sortBy;
                                receiptsSortDirection = 'asc';
                            }
                            receiptCurrentPage = 1;
                            renderReceiptsPage();
                        }
                        return;
                    }
                    if (!btn) return;
                    if (btn.id === 'print-report-btn') { printSummaryReport(); return; }
                    if (btn.classList.contains('pagination-btn')) {
                        receiptCurrentPage = Number(btn.dataset.page);
                        renderReceiptsPage();
                        return;
                    }
                    const billId = btn.dataset.billId;
                    if (btn.classList.contains('print-receipt-btn')) { printReceipt(billId); }
                    if (btn.classList.contains('delete-bill-btn')) {
                        actionAfterPassword = 'delete';
                        targetBillIdForAction = billId;
                        showModal('password-modal');
                    }
                    if (btn.classList.contains('edit-bill-btn')) {
                        actionAfterPassword = 'edit';
                        targetBillIdForAction = billId;
                        showModal('password-modal');
                    }
                });
            }

            modalContainer.addEventListener('click', e => {
                if (e.target.dataset.modalHide) hideModal(e.target.dataset.modalHide);
            });
            
            document.getElementById('confirm-delete-btn')?.addEventListener('click', async () => {
                const btn = document.getElementById('confirm-delete-btn');
                toggleButtonLoading(btn, true);
                try {
                    if (billToDeleteId) {
                        const billToDelete = savedBills.find(b => b.id === billToDeleteId);
                        if (billToDelete) {
                            const batch = writeBatch(db);
                            const billRef = doc(db, "bills", billToDeleteId);
                            batch.delete(billRef);
                            if (billToDelete.sourceEntryIds?.length > 0) {
                                billToDelete.sourceEntryIds.forEach(entryId => {
                                    const entryRef = doc(db, "receivingEntries", entryId);
                                    batch.update(entryRef, { billed: false });
                                });
                            }
                            await batch.commit();
                        }
                        billToDeleteId = null;
                    } else if (itemToDeleteId) {
                        await deleteDoc(doc(db, "receivingEntries", itemToDeleteId));
                        itemToDeleteId = null;
                    }
                } catch (error) {
                    console.error("Error during deletion:", error);
                    alert("เกิดข้อผิดพลาดระหว่างการลบข้อมูล");
                } finally {
                    toggleButtonLoading(btn, false);
                    hideModal('delete-confirm-modal');
                }
            });

            document.getElementById('edit-form')?.addEventListener('submit', async e => {
                e.preventDefault();
                const btn = e.target.querySelector('button[type="submit"]');
                const id = document.getElementById('edit-item-id').value;
                const name = document.getElementById('edit-name').value.trim();
                const bags = parseFloat(document.getElementById('edit-bags').value);
                if (name && !isNaN(bags) && bags >= 0) {
                    toggleButtonLoading(btn, true);
                    try {
                        const docRef = doc(db, "receivingEntries", id);
                        await updateDoc(docRef, { name, bags });
                        hideModal('edit-modal');
                    } catch(error) {
                        console.error("Error updating receiving entry:", error);
                        alert("เกิดข้อผิดพลาดในการแก้ไขข้อมูล");
                    } finally {
                        toggleButtonLoading(btn, false);
                    }
                }
            });
            
            document.getElementById('edit-bill-form')?.addEventListener('submit', async e => {
                e.preventDefault();
                const btn = e.target.querySelector('button[type="submit"]');
                const bill = savedBills.find(b => b.id === billToEditId);
                if (bill) {
                    const newWeight = parseFloat(document.getElementById('edit-bill-weight').value);
                    const newPrice = parseFloat(document.getElementById('edit-bill-price').value);
                    if (newWeight > 0 && newPrice > 0) {
                        toggleButtonLoading(btn, true);
                        try {
                            const billRef = doc(db, "bills", billToEditId);
                            await updateDoc(billRef, {
                                totalWeight: newWeight, pricePerUnit: newPrice, netAmount: newWeight * newPrice
                            });
                            hideModal('edit-bill-modal');
                        } catch(error) {
                            console.error("Error updating bill:", error);
                            alert("เกิดข้อผิดพลาดในการแก้ไขบิล");
                        } finally {
                            toggleButtonLoading(btn, false);
                        }
                    }
                }
            });

            document.getElementById('password-form')?.addEventListener('submit', e => {
                e.preventDefault();
                const passwordInput = document.getElementById('password-input');
                if (passwordInput.value === '9512') {
                    hideModal('password-modal');
                    if (actionAfterPassword === 'edit') {
                        billToEditId = targetBillIdForAction;
                        const bill = savedBills.find(b => b.id === billToEditId);
                        if (bill) {
                            document.getElementById('edit-bill-weight').value = bill.totalWeight;
                            document.getElementById('edit-bill-price').value = bill.pricePerUnit;
                            showModal('edit-bill-modal');
                        }
                    } else if (actionAfterPassword === 'delete') {
                        billToDeleteId = targetBillIdForAction;
                        itemToDeleteId = null;
                        showModal('delete-confirm-modal');
                    }
                    passwordInput.value = '';
                    actionAfterPassword = null;
                    targetBillIdForAction = null;
                } else {
                    alert('รหัสผ่านไม่ถูกต้อง!');
                    passwordInput.value = '';
                }
            });
            
            document.getElementById('truck-log-form')?.addEventListener('submit', async e => {
                e.preventDefault();
                const btn = e.target.querySelector('button[type="submit"]');
                const scaleId = document.getElementById('truck-log-scale-id').value;
                const truckType = document.getElementById('truck-type').value;
                const truckInfo = document.getElementById('truck-info').value.trim();

                if (!truckType || !truckInfo) {
                    alert('กรุณากรอกข้อมูลรถให้ครบถ้วน');
                    return;
                }

                toggleButtonLoading(btn, true);
                try {
                    const success = await executeSaveToTruck(scaleId, truckType, truckInfo);
                    if (success) {
                        alert('บันทึกข้อมูลขึ้นรถเรียบร้อยแล้ว');
                        hideModal('truck-log-modal');
                    } else {
                        alert(`ไม่มีน้ำหนักรอขึ้นรถสำหรับตาชั่ง ${scaleId.replace('scale-','')}`);
                        hideModal('truck-log-modal');
                    }
                } catch(error) {
                    console.error("Error during truck log save:", error);
                    alert("เกิดข้อผิดพลาดในการบันทึกขึ้นรถ");
                } finally {
                    toggleButtonLoading(btn, false);
                }
            });

            truckLogListContainer.addEventListener('click', (e) => {
                const btn = e.target.closest('button');
                if (!btn) return;

                const logId = btn.dataset.logId;
                const logDate = document.getElementById('truck-log-date-selector').value;
                const logEntry = truckLogs[logDate]?.find(log => log.id === logId);

                if (btn.classList.contains('edit-truck-log-btn')) {
                    if (logEntry) {
                        document.getElementById('edit-truck-log-id').value = logId;
                        document.getElementById('edit-truck-type').value = logEntry.truckType;
                        document.getElementById('edit-truck-info').value = logEntry.truckInfo;
                        showModal('edit-truck-log-modal');
                    }
                } else if (btn.classList.contains('view-truck-log-details-btn')) {
                    if (logEntry) {
                        const detailsContent = document.getElementById('truck-log-details-content');
                        let tableHTML = `
                                <p class="mb-2 text-gray-600"><strong>ประเภทรถ:</strong> ${logEntry.truckType}</p>
                                <p class="mb-4 text-gray-600"><strong>ทะเบียน/คนขับ:</strong> ${logEntry.truckInfo}</p>
                                <table class="min-w-full divide-y divide-gray-200">
                                    <thead class="bg-gray-50">
                                        <tr>
                                            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">ลำดับ</th>
                                            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">ชื่อผู้ขาย</th>
                                            <th class="px-4 py-2 text-center text-xs font-medium text-gray-500 uppercase">ตาชั่ง</th>
                                            <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">น้ำหนัก (กก.)</th>
                                        </tr>
                                    </thead>
                                    <tbody class="bg-white divide-y divide-gray-200">
                        `;
                        
                        logEntry.sellers.forEach((sellerString, index) => {
                            tableHTML += `<tr>
                                <td class="px-4 py-2">${index + 1}</td>
                                <td class="px-4 py-2">${sellerString.split(' (')[0]}</td>
                                <td class="px-4 py-2 text-center">${logEntry.scalesInvolved.join(', ')}</td>
                                <td class="px-4 py-2 text-right">${sellerString.match(/\(([^)]+)\)/)[1]}</td>
                            </tr>`;
                        });

                        tableHTML += `
                                    </tbody>
                                    <tfoot class="bg-gray-100">
                                        <tr>
                                            <td colspan="3" class="px-4 py-2 text-right font-bold">ยอดรวม:</td>
                                            <td class="px-4 py-2 text-right font-bold">${logEntry.totalWeight.toLocaleString('th-TH', {minimumFractionDigits: 2, maximumFractionDigits: 2})} กก.</td>
                                        </tr>
                                    </tfoot>
                                </table>
                        `;
                        
                        detailsContent.innerHTML = tableHTML;
                        showModal('truck-log-details-modal');
                    }
                }
            });

            document.getElementById('edit-truck-log-form')?.addEventListener('submit', async e => {
                e.preventDefault();
                const btn = e.target.querySelector('button[type="submit"]');
                const logId = document.getElementById('edit-truck-log-id').value;
                const newType = document.getElementById('edit-truck-type').value;
                const newInfo = document.getElementById('edit-truck-info').value.trim();
                
                if (newType && newInfo && logId) {
                    toggleButtonLoading(btn, true);
                    try {
                        const logRef = doc(db, "truckLogs", logId);
                        await updateDoc(logRef, { truckType: newType, truckInfo: newInfo });
                        hideModal('edit-truck-log-modal');
                        alert('แก้ไขข้อมูลเรียบร้อยแล้ว');
                    } catch(error) {
                        console.error("Error updating truck log:", error);
                        alert("เกิดข้อผิดพลาดในการแก้ไขข้อมูล");
                    } finally {
                        toggleButtonLoading(btn, false);
                    }
                }
            });
            
            window.addEventListener('afterprint', () => {
                document.body.classList.remove('printing-active', 'printing-receipt');
                const printContainer = document.getElementById('print-container');
                if(printContainer) {
                    printContainer.innerHTML = '';
                }
            });
        }
    </script>
</body>
</html>
