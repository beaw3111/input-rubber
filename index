    <script type="module">
        // Firebase Imports
        import { initializeApp } from "https://www.gstatic.com/firebasejs/9.22.0/firebase-app.js";
        import { getFirestore, collection, doc, addDoc, getDocs, setDoc, deleteDoc, updateDoc, query, onSnapshot, writeBatch } from "https://www.gstatic.com/firebasejs/9.22.0/firebase-firestore.js";
        import { getAuth, signInWithEmailAndPassword, signOut, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/9.22.0/firebase-auth.js";

        // Firebase Config
        const firebaseConfig = {
            apiKey: "AIzaSyDex2cApHn0JFejk3Mi4QXfYJyqoBjvzZ8",
            authDomain: "a110-d0d0a.firebaseapp.com",
            projectId: "a110-d0d0a",
            storageBucket: "a110-d0d0a.firebasestorage.app",
            messagingSenderId: "492280695567",
            appId: "1:492280695567:web:1e9bd5f2244c7a92d30c7a",
            measurementId: "G-4HJMTN359B"
        }; // แก้ไขปีกกาปิดที่ซ้ำซ้อนตรงนี้แล้ว

        // Initialize Firebase
        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);
        const auth = getAuth(app);

        // --- Global Elements ---
        const mainMenu = document.getElementById('main-menu');
        const pages = document.querySelectorAll('.page-content');
        const tabsContainer = document.getElementById('tabs');
        const tabContentContainer = document.getElementById('tab-content');
        const billingTabsContainer = document.getElementById('billing-tabs');
        const billingTabContentContainer = document.getElementById('billing-tab-content');
        const modalContainer = document.getElementById('modal-container');
        const sidebar = document.getElementById('sidebar');
        const sidebarToggle = document.getElementById('sidebar-toggle');
        const sidebarOverlay = document.getElementById('sidebar-overlay');
        const contentWrapper = document.getElementById('content-wrapper');
        const pageTitle = document.getElementById('page-title');
        const loadingOverlay = document.getElementById('loading-overlay');
        const loginContainer = document.getElementById('login-container');
        const appContainer = document.getElementById('app-container');
        const loginForm = document.getElementById('login-form');
        const loginError = document.getElementById('login-error');
        const logoutBtn = document.getElementById('logout-btn');

        // --- State Management ---
        let dailyData = {};
        let savedBills = [];
        let truckLogs = {};
        let weightEntries = {};
        let activePage = 'page-receiving';
        let activeTabId = 'scale-1';
        let activeBillingTabId = 'scale-1';
        let selectedDate = '';
        let itemToDeleteId = null;
        let billToDeleteId = null;
        let billToEditId = null;
        let isAppInitialized = false;
        let currentUserRole = null;

        // Search State
        let receivingSearchQueries = {};
        let billingHistorySearchQueries = {};
        let receiptsSearchQuery = '';

        // Pagination and Sorting State for Receipts Page
        let receiptCurrentPage = 1;
        const receiptsPerPage = 20;
        let receiptsSortColumn = 'timestamp';
        let receiptsSortDirection = 'asc';

        let receivingCurrentPage = { 'scale-1': 1, 'scale-2': 1, 'scale-3': 1, 'scale-4': 1 };
        const receivingItemsPerPage = 25;
        let billingHistoryCurrentPage = { 'scale-1': 1, 'scale-2': 1, 'scale-3': 1, 'scale-4': 1 };
        const billingHistoryItemsPerPage = 20;

        let actionAfterPassword = null;
        let targetBillIdForAction = null;

        // --- Helper Functions ---
        const getTodayDateString = () => new Date().toISOString().slice(0, 10);
        const formatThaiDate = (dateString) => new Date(dateString).toLocaleDateString('th-TH', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
        });
        const getScalesDataForDate = (date) => {
            if (!dailyData[date]) {
                dailyData[date] = { 'scale-1': [], 'scale-2': [], 'scale-3': [], 'scale-4': [] };
            }
            return dailyData[date];
        };

        function getSortIcon(column) {
            if (receiptsSortColumn !== column) {
                return '<i class="fas fa-sort text-gray-300 ml-1"></i>';
            }
            if (receiptsSortDirection === 'asc') {
                return '<i class="fas fa-sort-up text-gray-700 ml-1"></i>';
            } else {
                return '<i class="fas fa-sort-down text-gray-700 ml-1"></i>';
            }
        }
        
        function toggleButtonLoading(button, isLoading) {
            if (!button) return;

            if (isLoading) {
                if (!button.dataset.originalHtml) {
                    button.dataset.originalHtml = button.innerHTML;
                }
                button.disabled = true;
                button.innerHTML = `<i class="fas fa-spinner fa-spin mr-2"></i>กำลังดำเนินการ...`;
            } else {
                if (button.dataset.originalHtml) {
                    button.innerHTML = button.dataset.originalHtml;
                }
                button.disabled = false;
            }
        }

        // --- Modal Functions ---
        function showModal(modalId) {
            const modal = document.getElementById(modalId);
            if (modal) {
                modal.classList.remove('hidden');
            }
        }

        function hideModal(modalId) {
            const modal = document.getElementById(modalId);
            if (modal) {
                modal.classList.add('hidden');
            }
        }

        // --- Auth Handling ---
        onAuthStateChanged(auth, user => {
            if (user) {
                if (user.email === 'admin@coop.com') {
                    currentUserRole = 'admin';
                } else if (user.email === 'staff@coop.com') {
                    currentUserRole = 'staff';
                } else {
                    console.error("Unauthorized user tried to log in:", user.email);
                    loginError.textContent = "คุณไม่มีสิทธิ์เข้าใช้งานระบบ";
                    loginError.classList.remove('hidden');
                    signOut(auth);
                    return;
                }

                console.log(`User authenticated with role: ${currentUserRole}`);
                loginContainer.classList.add('hidden');
                appContainer.classList.remove('hidden');
                if (!isAppInitialized) {
                    loadingOverlay.classList.remove('hidden');
                    initializeLocalApp();
                    isAppInitialized = true;
                } else {
                    updateUIVisibility();
                }
                if (currentUserRole === 'staff' && (activePage === 'page-receipts' || activePage === 'page-monitor')) {
                    switchPage('page-receiving');
                }
            } else {
                console.log("User is signed out.");
                loginContainer.classList.remove('hidden');
                appContainer.classList.add('hidden');
                loadingOverlay.classList.add('hidden');
                isAppInitialized = false;
                currentUserRole = null;
            }
        });

        loginForm.addEventListener('submit', (e) => {
            e.preventDefault();
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            loginError.classList.add('hidden');

            signInWithEmailAndPassword(auth, email, password)
                .catch(error => {
                    console.error("Login failed:", error.code);
                    loginError.textContent = "อีเมลหรือรหัสผ่านไม่ถูกต้อง";
                    loginError.classList.remove('hidden');
                });
        });

        logoutBtn.addEventListener('click', () => {
            signOut(auth).catch(error => console.error("Sign out failed:", error));
        });

        function initializeLocalApp() {
            initializeUI();
            setupEventListeners();
            selectedDate = getTodayDateString();
            setupFirestoreListeners();
        }

        function setupFirestoreListeners() {
            let isInitialReceivingLoad = true;
            const receivingQuery = query(collection(db, "receivingEntries"));
            onSnapshot(receivingQuery, (snapshot) => {
                const allEntries = [];
                snapshot.forEach(doc => allEntries.push({ id: doc.id, ...doc.data() }));

                dailyData = {};
                allEntries.forEach(entry => {
                    if (!dailyData[entry.date]) {
                        dailyData[entry.date] = { 'scale-1': [], 'scale-2': [], 'scale-3': [], 'scale-4': [] };
                    }
                    if (!dailyData[entry.date][entry.scaleId]) {
                        dailyData[entry.date][entry.scaleId] = [];
                    }
                    dailyData[entry.date][entry.scaleId].push(entry);
                });

                for (const date in dailyData) {
                    for (const scale in dailyData[date]) {
                        dailyData[date][scale].sort((a,b) => a.timestamp - b.timestamp);
                    }
                }

                updateDateDropdowns();
                refreshCurrentPage();
                if (isInitialReceivingLoad) {
                    updateUIVisibility();
                    switchPage('page-receiving');
                    loadingOverlay.style.display = 'none';
                    isInitialReceivingLoad = false;
                }
            });

            const billsQuery = query(collection(db, "bills"));
            onSnapshot(billsQuery, (snapshot) => {
                savedBills = [];
                snapshot.forEach(doc => {
                    savedBills.push({ id: doc.id, ...doc.data() });
                });
                updateDateDropdowns();
                refreshCurrentPage();
            });

            const truckLogsQuery = query(collection(db, "truckLogs"));
            onSnapshot(truckLogsQuery, (snapshot) => {
                truckLogs = {};
                snapshot.forEach(doc => {
                    const log = { id: doc.id, ...doc.data() };
                    if (!truckLogs[log.date]) {
                        truckLogs[log.date] = [];
                    }
                    truckLogs[log.date].push(log);
                });
                for(const date in truckLogs) {
                    truckLogs[date].sort((a,b) => a.timestamp - b.timestamp);
                }
                refreshCurrentPage();
            });
        }
        
        function refreshCurrentPage() {
            if (!isAppInitialized) return;
            if (activePage === 'page-receiving') {
                switchTab(activeTabId);
            } else if (activePage === 'page-billing') {
                switchBillingTab(activeBillingTabId);
            } else if (activePage === 'page-receipts') {
                renderReceiptsPage();
            } else if (activePage === 'page-truck-log') {
                renderTruckLogPage();
            } else if (activePage === 'page-monitor') {
                renderMonitorPage();
            }
        }
        
        function printReceipt(billId) {
            const bill = savedBills.find(b => b.id === billId);
            if (!bill) return;
            const billsOnSameDate = savedBills.filter(b => b.date === bill.date);
            billsOnSameDate.sort((a, b) => a.timestamp - b.timestamp);
            const queueNumber = billsOnSameDate.findIndex(b => b.id === bill.id) + 1;
            const datePart = `${new Date(bill.date).getFullYear()}${(new Date(bill
