        async function executeSaveToTruck(scaleId, truckType, truckInfo) {
            const billsToLoad = savedBills.filter(b => b.date === selectedDate && b.scaleId === scaleId && !b.loadedOnTruck);
            if (billsToLoad.length === 0) {
                console.log(`No bills to load for ${scaleId}. Skipping save.`);
                return false;
            }

            const totalWeight = billsToLoad.reduce((sum, bill) => sum + bill.totalWeight, 0);
            const sellers = [...new Set(billsToLoad.map(b => `${b.farmerName} (${b.totalWeight} กก.)`))];
            
            try {
                const batch = writeBatch(db);
                const newLogRef = doc(collection(db, "truckLogs"));
                batch.set(newLogRef, {
                    date: selectedDate,
                    timestamp: Date.now(),
                    truckType,
                    truckInfo,
                    totalWeight,
                    scalesInvolved: [scaleId.replace('scale-', '')],
                    sellers
                });

                billsToLoad.forEach(bill => {
                    const billRef = doc(db, "bills", bill.id);
                    batch.update(billRef, { loadedOnTruck: true });
                });

                await batch.commit();

                truckWeightTargets[scaleId] = 0;
                const targetInput = document.getElementById(`truck-target-weight-${scaleId}`);
                if(targetInput) targetInput.value = '';
                return true;
            } catch (error) {
                console.error("Error saving truck log: ", error);
                alert("เกิดข้อผิดพลาดในการบันทึกขึ้นรถ");
                return false;
            }
        }
        
