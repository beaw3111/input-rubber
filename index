        function updateDateDropdowns() {
            const dateSelectors = [
                document.getElementById('date-selector'),
                document.getElementById('billing-date-selector'),
                document.getElementById('receipts-date-selector'),
                document.getElementById('truck-log-date-selector'),
                document.getElementById('monitor-date-selector')
            ].filter(Boolean);

            const datesFromReceiving = Object.keys(dailyData);
            const datesFromBills = savedBills.map(b => b.date);
            const allDates = [...new Set([...datesFromReceiving, ...datesFromBills])].sort().reverse();
            const today = getTodayDateString();
            if (!allDates.includes(today)) {
                allDates.unshift(today);
            }
            dateSelectors.forEach(selector => {
                if (!selector) return;
                const currentValue = selector.value;
                selector.innerHTML = '';

                if (selector.id === 'receipts-date-selector') {
                    selector.innerHTML += `<option value="all">แสดงทั้งหมด</option>`;
                }

                allDates.forEach(date => {
                    const option = document.createElement('option');
                    option.value = date;
                    option.textContent = formatThaiDate(date) + (date === today ? ' (วันนี้)' : '');
                    selector.appendChild(option);
                });

                if (currentValue && (allDates.includes(currentValue) || currentValue === 'all')) {
                    selector.value = currentValue;
                } else {
                    selector.value = selectedDate;
                }
            });
        }

