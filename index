            let billsToPrint = savedBills;
            if (reportDate && reportDate !== 'all') {
                billsToPrint = savedBills.filter(bill => bill.date === reportDate);
            }

            const sortedBills = [...billsToPrint].sort((a, b) => a.timestamp - b.timestamp);
            if (sortedBills.length === 0) {
                alert('ไม่มีข้อมูลสำหรับพิมพ์รายงานในวันที่เลือก');
                return;
            }

            const itemsPerPage = 20;
            const totalPages = Math.ceil(sortedBills.length / itemsPerPage);
            let allPagesHTML = '';

            const grandTotalWeight = sortedBills.reduce((sum, bill) => sum + bill.totalWeight, 0);
            const grandTotalValue = sortedBills.reduce((sum, bill) => sum + Math.floor(bill.netAmount), 0);
            const reportDateString = (reportDate && reportDate !== 'all') ? formatThaiDate(reportDate) : 'ทั้งหมด';

            for (let i = 0; i < totalPages; i++) {
                const startIndex = i * itemsPerPage;
